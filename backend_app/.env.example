# Smart Parking Mobile Backend - Environment Variables
# Copy this file to .env and fill in your values

# Flask
FLASK_ENV=production
SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_URL=postgresql://postgres:1412@localhost:5432/PARKING_PLATE

# Internal API secret for main app (port 5001) to call backend app (port 5002)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_SECRET=

# Server
APP_PORT=5002
