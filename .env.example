# RTSP Camera URLs (production)
# Dahua Main Stream: /cam/realmonitor?channel=1&subtype=0
# Dahua Sub Stream : /cam/realmonitor?channel=1&subtype=1
# Thay IP va credentials phu hop voi camera cua ban
PARKING_RTSP_URL=rtsp://USERNAME:PASSWORD@YOUR_CAMERA_IP/cam/realmonitor?channel=1&subtype=1
GATE_RTSP_URL=rtsp://USERNAME:PASSWORD@YOUR_CAMERA_IP/cam/realmonitor?channel=1&subtype=0

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
ALLOWED_HOSTS=*

# Flask secret key (generate: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_HEX

# Detection
MIN_CONFIDENCE=0.35
MIN_AREA_SIZE=1500
MIN_DIMENSION=30

# Gate Camera Lines (pixel Y coordinates on 1020x500 resized frame)
GATE_LINE_1_Y=80
GATE_LINE_2_Y=360

# Parking Camera
PARKING_DISPLAY_WIDTH=1020
PARKING_DISPLAY_HEIGHT=500
PARKING_STARTUP_FRAMES=30
PARKING_SLOT_EMPTY_THRESHOLD=45

# Upscale display
PARKING_UPSCALE_DISPLAY=True
PARKING_UPSCALE_WIDTH=1920
PARKING_UPSCALE_HEIGHT=1080

# Performance Optimization
PARKING_USE_HALF_PRECISION=True
PARKING_USE_CLAHE=False
PARKING_USE_DETECTION_THREAD=True
PARKING_USE_ROBUST_RTSP=True
PARKING_ENABLE_SKIP_MONITORING=True

# Database (PostgreSQL)
# Thay PASSWORD phu hop
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/PARKING_PLATE
