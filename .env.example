# RTSP Camera URLs (production)
# Example: rtsp://username:password@ip:port/path
# Dahua Main Stream: /cam/realmonitor?channel=1&subtype=0
# Dahua Sub Stream : /cam/realmonitor?channel=1&subtype=1
#PARKING_RTSP_URL=rtsp://username:password@192.168.x.x/cam/realmonitor?channel=1&subtype=1
#GATE_RTSP_URL=rtsp://username:password@192.168.x.x/cam/realmonitor?channel=1&subtype=0

# RTSP Camera URLs (simulator - mediamtx local)
# Start simulator: cd simulator && docker-compose up -d && python stream.py
PARKING_RTSP_URL=rtsp://localhost:8554/cam_parking
GATE_RTSP_URL=rtsp://localhost:8554/cam_gate

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5001
ALLOWED_HOSTS=*

# Detection
MIN_CONFIDENCE=0.35
MIN_AREA_SIZE=1500
MIN_DIMENSION=30

# Gate Camera Lines (pixel Y coordinates on 1020x500 resized frame)
GATE_LINE_1_Y=80
GATE_LINE_2_Y=360

# Parking Camera
PARKING_DISPLAY_WIDTH=1020
PARKING_DISPLAY_HEIGHT=500
PARKING_STARTUP_FRAMES=30
PARKING_SLOT_EMPTY_THRESHOLD=45

# Upscale display - phóng to substream lên 1080p cho hiển thị đẹp hơn
# Chỉ ảnh hưởng MJPEG output, không ảnh hưởng detection
PARKING_UPSCALE_DISPLAY=True
PARKING_UPSCALE_WIDTH=1920
PARKING_UPSCALE_HEIGHT=1080

# ============ Performance Optimization ============
# Half precision (FP16) - 20-40% faster on GPU with minimal accuracy loss
# Requires: NVIDIA GPU with CUDA support
PARKING_USE_HALF_PRECISION=True

# CLAHE (Contrast enhancement) - improves detection in low light but adds ~5-10% overhead
# Set to True for night/low-light conditions, False for good lighting
PARKING_USE_CLAHE=False

# Detection thread - run YOLO inference in separate thread (15-30% faster)
# Recommended: True for better performance
PARKING_USE_DETECTION_THREAD=True

# RTSP reconnection - auto-reconnect on stream failure
# Recommended: True for production environments
PARKING_USE_ROBUST_RTSP=True

# Frame skip monitoring - log frame skip rate and FPS every 5 seconds
# Useful for debugging performance issues
PARKING_ENABLE_SKIP_MONITORING=True

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/PARKING_PLATE

# ============ Docker / Production ============
# PostgreSQL credentials (used by docker-compose)
POSTGRES_DB=PARKING_PLATE
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Flask Secret Keys (CHANGE THESE IN PRODUCTION!)
FLASK_SECRET_KEY=change-me-in-production
BACKEND_SECRET_KEY=change-me-in-production

# Backend API port
BACKEND_PORT=5002
BACKEND_APP_URL=http://localhost:5002

# GPU Configuration
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_GPU_COUNT=1

# Flask environment
FLASK_ENV=production
